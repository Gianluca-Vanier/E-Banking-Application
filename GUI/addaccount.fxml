<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="280.0" prefWidth="380.0" spacing="20.0"
      style="-fx-background-color: #f5f7fa;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="GUI.AddAccountController">
    <padding><Insets topRightBottomLeft="30.0"/></padding>

    <Label text="Open New Account" style="-fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 20; -fx-text-fill: navy;"/>

    <Label text="Select Account Type:" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 13;"/>

    <ComboBox fx:id="accountTypeCombo" prefWidth="280.0"/>

    <Label fx:id="errorLabel"
           text="Error"
           style="-fx-text-fill: red; -fx-font-family: 'Segoe UI'; -fx-font-size: 12;"
           wrapText="true"/>

    <HBox spacing="15.0" alignment="CENTER">
        <Button text="Confirm" fx:id="confirmButton"
                onAction="#onConfirm"
                prefWidth="120.0" prefHeight="36.0"
                style="-fx-background-color: navy; -fx-text-fill: white;
                       -fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 13;
                       -fx-background-radius: 6;"/>
        <Button text="Cancel"
                onAction="#onCancel"
                prefWidth="120.0" prefHeight="36.0"
                style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;
                       -fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 13;
                       -fx-background-radius: 6;"/>
    </HBox>
</VBox>